# ============================================================
# ORA Studio — Environment variables
# ============================================================
# Frontend (Vite) uses the values hardcoded in utils/supabase/info.tsx
# (public anon key + project id, both safe to expose). Nothing in this
# file is required for the frontend build.
#
# All variables below MUST be configured server-side via
#   supabase secrets set --env-file .env.edge
# Then deployed with
#   supabase functions deploy server
# ============================================================

# ─── Supabase (auto-populated by `supabase secrets set`) ──────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...                   # never commit — server-only

# ─── Admin bootstrap ─────────────────────────────────────────
# Email that gets promoted to role=admin on FIRST signup only.
# Subsequent admins must be promoted via /admin/users/:userId/plan.
# If unset, no email-based bypass exists (recommended for production
# once the initial admin profile is created).
ADMIN_EMAIL=

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                              # used by /stripe/webhook signature check
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_CREATOR_YEARLY=price_...
STRIPE_PRICE_STUDIO_YEARLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...
STRIPE_PRICE_PACK_S=price_...
STRIPE_PRICE_PACK_M=price_...
STRIPE_PRICE_PACK_L=price_...

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── AI providers ────────────────────────────────────────────
# Text (cascading: APIPod -> direct OpenAI fallback)
APIPOD_API_KEY=
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=                                           # optional, used by some flows
GOOGLE_GENAI_API_KEY=                                        # optional

# Image generation
RUNWARE_API_KEY=
FAL_API_KEY=                                                 # fallback when Runware is down
REPLICATE_API_TOKEN=                                         # tertiary fallback + audio (MusicGen)
LEONARDO_API_KEY=
IDEOGRAM_API_KEY=
PHOTOROOM_API_KEY=                                           # background removal + product compositing

# Video generation
POLLO_API_KEY=
POLLO_WEBHOOK_SECRET=                                        # ROTATE — previously hardcoded, see commit history

# Audio
SUNO_API_KEY=
ELEVENLABS_API_KEY=

# ─── Web scraping (Brand Vault) ──────────────────────────────
JINA_API_KEY=
FIRECRAWL_API_KEY=                                           # optional fallback
SCRAPINGBEE_API_KEY=                                         # optional fallback

# ─── Social publishing ───────────────────────────────────────
POSTFORME_API_KEY=
ZERNIO_API_KEY=                                              # if using Zernio publish path

# ─── Observability ───────────────────────────────────────────
# Slack webhook used for cost spike / error rate alerts (planned).
SLACK_ALERTS_WEBHOOK=
